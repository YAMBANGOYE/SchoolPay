 <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navbar -->
           {{>menu}}

            <!-- Settings Content -->
         
                <!-- Settings Navigation -->
                

                <!-- Settings Content -->
                <div class="glass-card">
                    <!-- Profile Tab -->
                    <form action="/paiements/tarifs" method="POST">

                    <div class="settings-tab-content active" id="tab-profile">
                        <div class="profile-header">
                           
                            <div class="profile-info">
                                
                                <p></p>
                            </div>
                        </div>

                        <div class="settings-section">

                            <div class="form-grid">
                                <div class="form-group-settings">
                                    <label>Libelle</label>
                                    <input type="text"  name="libelle" placeholder="" >
                                </div>
                                 <div class="form-group-settings">
                                      <label for="exampleFormControlSelect1" class="form-label">Type de paiement</label>
                                            <select class="settings-select" id="exampleFormControlSelect1" name="type">
                                                <option value="">-- Selectionner type de paiement --</option>
                                                <option value="unique">Unique</option>
                                                <option value="mensuel">Mensuel</option>
                                                <option value="annuel">Annuel</option>

                                            </select>
                                </div>
                                <div class="form-group-settings">
                                    <label>Montant</label>
                                    <input type="number"  name="montant" placeholder="" >
                                </div>
                                 <div class="form-group-settings">
                                    <div class="settings-label">
                                        <span class="settings-label-title">Paiement obligatoire</span>
                                        <span class="settings-label-desc">Ce paiement est obligatoire pour tous les élèves</span>
                                    </div>
                                    <label class="toggle-switch">
                                        <input type="checkbox" name="obligatoire" value="true">
                                        <span class="toggle-slider"></span>
                                    </label>
                                </div>
                               
                            </div>
                        </div>
                        <div class="btn-group">
                            <button class="btn btn-primary" style="width: auto;">Save Changes</button>
                            <button class="btn btn-secondary" style="width: auto;">Cancel</button>
                        </div>
                    </div>
            </form>
                    <!-- Security Tab -->
                    
                    <!-- Notifications Tab -->
                    
                    <!-- Billing Tab -->
                    <div class="settings-tab-content" id="tab-billing">
                        

                        
                    
                    </div>
                </div>
            </div>
        </main>
    </div>