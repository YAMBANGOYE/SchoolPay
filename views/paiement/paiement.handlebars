<!-- Main Content -->
<main class="main-content">
    <!-- Top Navbar -->
    {{>menu}}

    <!-- Settings Content -->

    <!-- Settings Navigation -->

    <!-- Settings Content -->
    <div class="glass-card">
        <!-- Profile Tab -->
        <form action="/paiements/paiement" method="POST">

            <div class="settings-tab-content active" id="tab-profile">
                <div class="profile-header">

                    <div class="profile-info">

                        <p></p>
                    </div>
                </div>

                <div class="settings-section">

                    <div class="form-grid">
                        <div class="form-group-settings">
                            <label for="exampleFormControlSelect1" class="form-label">Eleve</label>
                            <select class="settings-select" id="eleveSelect" name="inscription">
                                <option value="">-- Selectionner un eleve</option>

                                {{#each Inscription}}
                               <option 
value="{{this._id}}"
data-factures='{{json this.factures}}'
>
{{this.eleve.nom}}
</option>
                                {{/each}}

                            </select>
                        </div>

                        <div class="form-group-settings">
                            <label for="paiementSelect" class="form-label">Catégorie de paiement</label>
                            <select class="settings-select" id="paiementSelect" name="paiementId">
                                <option value="">-- Sélectionner une catégorie --</option>

                                {{#each Paiement}}
                                <option 
                                value="{{this.paiement._id}}" 
                                data-reste="{{this.reste}}">

                                {{this.paiement.libelle}} - Reste : {{this.reste}} FCFA

                                </option>
                                {{/each}}

                            </select>
                        </div>

                        <div class="form-group-settings">
                            <label>Reste à payer</label>
                            <input type="text" id="montantInput" name="montantTotal" placeholder="" readonly>
                        </div>

                        <div class="form-group-settings">
                            <label>Montant payer</label>
                            <input type="text" name="montantPaye" placeholder="">
                        </div>
                        <div class="form-group-settings">
                            <label>Debiteur</label>
                            <input type="text" name="debiteur" placeholder="Nom et prenom">
                        </div>
                    </div>
                </div>
                <div class="btn-group">
                    <button class="btn btn-primary" style="width: auto;">Save Changes</button>
                    <button class="btn btn-secondary" style="width: auto;">Cancel</button>
                </div>
            </div>
        </form>
        <!-- Security Tab -->

        <!-- Notifications Tab -->

        <!-- Billing Tab -->
        <div class="settings-tab-content" id="tab-billing">




        </div>
    </div>
    </div>
</main>
</div>
<script>

const eleveSelect = document.getElementById("eleveSelect");
const paiementSelect = document.getElementById("paiementSelect");
const montantInput = document.getElementById("montantInput");

let facturesEleve = [];

eleveSelect.addEventListener("change", function () {

    const selectedOption = this.options[this.selectedIndex];
    const factures = selectedOption.getAttribute("data-factures");

    paiementSelect.innerHTML = '<option value="">-- Sélectionner une catégorie --</option>';
    montantInput.value = "";

    if (factures) {

        facturesEleve = JSON.parse(factures);

        const categoriesAjoutees = new Set(); // évite les doublons

        facturesEleve.forEach(f => {

            if (!categoriesAjoutees.has(f.paiementId)) {

                const option = document.createElement("option");

                option.value = f.paiementId;
                option.textContent = f.libelle;

                paiementSelect.appendChild(option);

                categoriesAjoutees.add(f.paiementId);
            }

        });

    }

});


paiementSelect.addEventListener("change", function () {

    const paiementId = this.value;

    const facture = facturesEleve.find(f => f.paiementId === paiementId);

if (facture) {
    montantInput.value = facture.reste + " FCFA";
}

});

</script>